# =====================================================================
#  Unreal Engine 5 + CUDA project .gitignore
#  Tracks: source (.cpp/.h/.cs/.cu/.cuh), CudaLibrary.vcxproj, Config/,
#          Content/ assets, .uproject, CLAUDE.md, docs.
#  Ignores: every regenerable build/intermediate/cache/local file.
# =====================================================================

# ---------------------------------------------------------------------
# Unreal Engine generated folders (regenerated by the editor / UBT)
# ---------------------------------------------------------------------
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Built map data and editor autosaves
*_BuiltData.uasset
*.autosave

# Large source art originals (keep cooked Content/ .uasset, drop raw art)
SourceArt/**/*.png
SourceArt/**/*.tga
SourceArt/**/*.psd

# ---------------------------------------------------------------------
# CUDA static-library build output
# The .lib is rebuilt from CudaLibrary/CudaLibrary.vcxproj (VS 2022, Release|x64).
# ---------------------------------------------------------------------
x64/
Win32/
*.cu.obj
*.cu.cache
*.deps
*.ptx
*.cubin
*.fatbin

# ---------------------------------------------------------------------
# Visual Studio / VS Code  (regenerable project & local-user files)
# NOTE: CudaLibrary/CudaLibrary.vcxproj is hand-maintained -> kept on purpose.
# ---------------------------------------------------------------------
.vs/
.vscode/
*.sln
*.suo
*.user
*.vcxproj.user
*.vcxproj.filters
*.code-workspace
*.VC.db
*.VC.opendb
*.vsidx
*.opensdf
*.sdf
*.opendb

# ---------------------------------------------------------------------
# Compiled binaries / intermediates / debug symbols
# ---------------------------------------------------------------------
*.obj
*.o
*.lib
*.a
*.dll
*.so
*.dylib
*.exe
*.out
*.app
*.pch
*.gch
*.pdb
*.idb
*.ipdb
*.iobj
*.exp
*.ilk
*.tlog
*.lastbuildstate
*.recipe

# ---------------------------------------------------------------------
# Archived UE4 project (bf-sph-ue4): keep the SOURCE for reference, but skip
# the heavy demo Content (StarterContent etc.) — it is already in git history
# (commit 6de9566) and is not needed to read the old SPH code.
# ---------------------------------------------------------------------
bf-sph-ue4/Content/

# ---------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*~
*.swp
*.tmp
